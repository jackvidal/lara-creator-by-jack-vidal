# ─── Lara Creator — .env.local template ─────────────────────────────────────
# Copy to .env.local in the project root. Never commit .env.local.
# On Windows, before npm run dev, ALWAYS unset stale shell vars first:
#   unset DATABASE_URL DIRECT_URL ANTHROPIC_API_KEY FAL_API_KEY KIE_API_KEY \
#         BLOTATO_API_KEY OWNER_EMAIL SUPABASE_SERVICE_ROLE_KEY 2>/dev/null

# ─── Supabase (Phase 2) ──────────────────────────────────────────────────────
# Pooled connection used at runtime by Prisma. Port 6543, pgbouncer mode.
# &connection_limit=20 is REQUIRED for Railway — without it the worker hits
# "too many connections" under modest load.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20"

# Direct connection used by Prisma CLI (db push, migrations). Port 5432.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# Service role key — required for Storage uploads (mirror).
# Project Settings → API → "service_role" → Reveal.
# Newer projects start with sb_secret_*; older are JWT-format.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ─── Anthropic Claude (Phase 3) ──────────────────────────────────────────────
# Used by research (Haiku 4.5), content/review/learning (Opus 4.7).
# Without this key the agents fall back to mock content.
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── Image / Video Providers (Phase 4) — pick one or both ───────────────────
# Kie.ai (recommended default for Nano Banana 2)
KIE_API_KEY=""

# Fal.ai (alternate)
FAL_API_KEY=""

# ─── Blotato (Phase 5, optional) ─────────────────────────────────────────────
# Required only if you want real publishing to FB / IG / LinkedIn.
# Without this key, schedules stay in "scheduled" status and never fan out.
BLOTATO_API_KEY=""

# ─── Single-owner auth (Phase 8) ─────────────────────────────────────────────
# Only this email can ever log in. Lowercase, no quotes.
OWNER_EMAIL="you@example.com"

# ─── App URL (used in fetch UA + cookie secure flag) ────────────────────────
# Local: http://localhost:3000
# Railway: https://your-domain.up.railway.app  (or your custom domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Cron secret (legacy — used only if you fall back to pg_cron) ───────────
# Not needed on Railway. Leave empty unless you're rolling back to Vercel.
CRON_SECRET=""
